{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "installCommand": "pip install -r requirements.txt && cd frontend && npm ci",
  "buildCommand": "bash scripts/vercel-build.sh",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
